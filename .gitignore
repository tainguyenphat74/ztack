# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo

# CLI bundles a copy of templates/ at build time — don't commit the copy
/packages/cli/templates/

# env — never commit any env file
.env*

# logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
.idea/
.vscode/

# next.js artifacts (in case templates are built in place)
.next/
out/

# scaffolding test output
/tmp-scaffold/
