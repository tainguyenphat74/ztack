{
  "name": "ztack-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "ztack — a personal CLI for scaffolding project boilerplates",
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "cli": "bun run packages/cli/src/index.ts",
    "format": "prettier --write \"packages/**/*.{ts,json,md}\" \"*.{json,md}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,json,md}\" \"*.{json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.8.4"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
